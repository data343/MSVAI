# MSVAI Weekly Reports - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Required: Slack User Token
# Get this from https://api.slack.com/apps -> Your App -> OAuth & Permissions -> User OAuth Token
# Should start with 'xoxp-'
SLACK_USER_TOKEN=xoxp-your-slack-user-token-here

# Optional: OpenRouter API Key for AI-powered reply generation
# Get this from https://openrouter.ai/ -> Account -> API Keys
# Only needed if you want to use the AI reply feature (option 'a' when replying to reports)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Note: Never commit your actual .env file to git - it contains sensitive information!